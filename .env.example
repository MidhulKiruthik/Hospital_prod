# Copy this file to .env and replace every placeholder before public deployment.

APP_ENV=development

SECRET_KEY=replace-with-a-long-random-secret
JWT_SECRET_KEY=replace-with-a-long-random-jwt-secret
DATA_ENCRYPTION_KEY=replace-with-a-base64-32-byte-key

RAZORPAY_KEY_ID=replace-with-your-razorpay-key-id
RAZORPAY_KEY_SECRET=replace-with-your-razorpay-key-secret
RAZORPAY_SIGNATURE_REQUIRED=True

POSTGRES_DB=hospital_ops
POSTGRES_USER=hospital_ops
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
DATABASE_URL=postgresql://hospital_ops:replace-with-a-strong-postgres-password@postgres:5432/hospital_ops
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_STORAGE_URI=redis://localhost:6379/0
DEBUG=False
AUTO_RUN_MIGRATIONS=True
AUTO_CREATE_SCHEMA=False
AUTO_RUN_MIGRATIONS_WORKER=False
AUTO_CREATE_SCHEMA_WORKER=False
AUTO_RUN_MIGRATIONS_BEAT=False
AUTO_CREATE_SCHEMA_BEAT=False

# Security and API protection
AUTH_RATE_LIMIT=5 per minute
DEFAULT_RATE_LIMIT=300 per hour
ENFORCE_HTTPS=False
CORS_ORIGINS=http://localhost:8080,https://localhost:8443
CORS_ORIGINS_PRODUCTION=https://hospital.example.com
ALLOW_PRIVILEGED_SELF_REGISTRATION=False
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
REFRESH_TOKEN_EXPIRATION_DAYS=7
SECURITY_EVENT_EXPORT_ENABLED=False
SECURITY_EVENT_WEBHOOK_URL=
SECURITY_EVENT_WEBHOOK_TIMEOUT_SECONDS=3
SECURITY_EVENT_WEBHOOK_TOKEN=

# Demo data and bootstrap controls
SEED_DEMO_DATA=False
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_EMAIL=admin@hospital.local

# Observability
ENABLE_PROMETHEUS_METRICS=True
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-grafana-password
GRAFANA_ANONYMOUS_ENABLED=False
ALLOW_SELF_SIGNED_TLS=False

# Model selection
FORECAST_MODEL=baseline
ENABLE_TRANSFORMER_SUMMARIZATION=False
TRANSFORMER_MODEL_NAME=sshleifer/distilbart-cnn-12-6

# Backup and retention
BACKUP_DIR=./backups
BACKUP_RETENTION_HOURS=48
BACKUP_INTERVAL_MINUTES=15
BACKUP_HEALTH_MAX_AGE_MINUTES=30
BACKUP_HEALTH_CHECK_ENABLED=False
